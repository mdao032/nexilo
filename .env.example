# =============================================================================
# Nexilo — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs réelles.
# NE PAS committer le fichier .env dans Git.
# =============================================================================

# --- Anthropic Claude (requis pour le service IA) ---
# Obtenez votre clé sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Base de données PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexilo_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- JWT ---
# Clé secrète HMAC-256 en hexadécimal (64 caractères minimum)
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000

# --- Google Gemini (ancien provider, désactivé) ---
# GOOGLE_AI_API_KEY=your_google_ai_key_here

